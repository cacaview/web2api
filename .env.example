# Web2API Configuration

# 应用配置
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 浏览器配置
MAX_WORKERS=5

# Redis配置 (可选 - 无Redis时以独立模式运行)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 数据库
DB_PATH=./data/web2api.db

# Gemini特定配置
# 注：需要通过Playwright自动化处理登录认证
GEMINI_BASE_URL=https://gemini.google.com
